<% content_for :title, @page_title %>

<section>
  <h1><%= @faq["title"] %></h1>
  <p><%= @faq["intro"] %></p>

  <% if @faq["items"]&.any? %>
    <ul>
      <% @faq["items"].each do |item| %>
        <li>
          <strong><%= item["question"] %></strong>
          <p><%= item["answer"] %></p>
        </li>
      <% end %>
    </ul>
  <% end %>

  <nav>
    <%= link_to "About", "/about" %> |
    <%= link_to "Contact", "/contact" %> |
    <%= link_to "FAQ", "/faq" %>
  </nav>
</section>
