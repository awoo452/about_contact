<% content_for :title, @page_title %>

<section>
  <h1><%= @contact["title"] %></h1>
  <p><%= @contact["intro"] %></p>

  <% if flash[:notice].present? %>
    <p><%= flash[:notice] %></p>
  <% end %>
  <% if flash[:alert].present? %>
    <p><%= flash[:alert] %></p>
  <% end %>

  <% if @contact["details"]&.any? %>
    <ul>
      <% @contact["details"].each do |detail| %>
        <li><strong><%= detail["label"] %>:</strong> <%= detail["value"] %></li>
      <% end %>
    </ul>
  <% end %>

  <%= form_with scope: :contact, url: contact_path, method: :post do |form| %>
    <div>
      <%= form.label :name %>
      <%= form.text_field :name, value: @form_data["name"], required: true %>
    </div>

    <div>
      <%= form.label :email %>
      <%= form.email_field :email, value: @form_data["email"], required: true %>
    </div>

    <div>
      <%= form.label :message %>
      <%= form.text_area :message, value: @form_data["message"], rows: 6, required: true %>
    </div>

    <%= form.submit(@contact.dig("form", "submit_label") || "Send") %>
  <% end %>

  <% if @contact["social"]&.any? %>
    <h2>Social</h2>
    <ul>
      <% @contact["social"].each do |link| %>
        <li><%= link_to link["label"], link["url"], target: "_blank", rel: "noopener" %></li>
      <% end %>
    </ul>
  <% end %>

  <nav>
    <%= link_to "About", "/about" %> |
    <%= link_to "Contact", "/contact" %> |
    <%= link_to "FAQ", "/faq" %>
  </nav>
</section>
